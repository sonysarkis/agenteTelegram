# ═══════════════════════════════════════════════════════════
# Agente Telegram PM — Variables de Entorno
# ═══════════════════════════════════════════════════════════
# Copia este archivo como .env y rellena los valores.
# NUNCA subas el archivo .env real a GitHub.

# ── Telegram Bot ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=aqui_va_el_token_de_botfather
BOSS_USER_ID=123456789

# ── Groq (IA gratuita y ultrarrápida) ────────────────────
GROQ_API_KEY=gsk_tu_api_key_de_groq

# ── Notion ────────────────────────────────────────────────
NOTION_TOKEN=secret_tu_token_de_notion
NOTION_DATABASE_ID=tu_database_id_de_32_caracteres

# ── Webhook (URL de Render) ──────────────────────────────
WEBHOOK_URL=https://tu-servicio.onrender.com
