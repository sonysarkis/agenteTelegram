# ═══════════════════════════════════════════════════════════
# Agente Telegram PM — Variables de Entorno
# ═══════════════════════════════════════════════════════════
# Copia este archivo como .env y rellena los valores.
# NUNCA subas el archivo .env real a GitHub.

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="tu_token_de_bot_aqui"
# Lista de IDs de Telegram autorizados (separados por coma)
# Ejemplo: BOSS_USER_ID,YOUR_USER_ID
AUTHORIZED_USER_IDS="12345678,87654321"

# ── Groq (IA ultrarrápida y gratuita) ────────────────────
# Consigue tu API Key aquí: https://console.groq.com/
GROQ_API_KEY="gsk_tu_api_key_aqui"
GROQ_MODEL="llama-3.3-70b-versatile"

# ── Jira ──────────────────────────────────────────────────
# Ejemplo: https://tu-dominio.atlassian.net
JIRA_URL="https://tu-dominio.atlassian.net"
JIRA_EMAIL="tu-email@dominio.com"
# Token generado en: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN="tu_api_token_aqui"
# El código corto de tu proyecto (ej: KAN, DEV)
JIRA_PROJECT_KEY="PROJ"

# ── App ───────────────────────────────────────────────────
# URL de tu app en Render (ej: https://agente-pm.onrender.com)
WEBHOOK_URL="https://tu-app.onrender.com"
PORT=5000
